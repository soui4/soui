    <splitrow name="xml_editor" sepSkin="" size="-2,-2" sepSize="6">
      <pane idealSize="10" minSize="10" priority="0" clipClient="1">
        <realwnd pos="0, 0, -0, -0" name="uidesigner_wnd_layout" wndclass="designer_wnd" id="100000" wndname="designer_wnd"/>
      </pane>
      <pane idealSize="300" minSize="30" priority="1" clipClient="1" layout="vbox">      
        <realwnd size="-2,-2" name="uidesigner_scintilla" wndclass="scintilla" id="100000" wndname="scintilla"/>
      </pane>
    </splitrow>
  </page>
  <page name="page_image" title="@string/image_viewer" layout="hbox">
     <window size="0, -2" weight="1" skin="skin_designer_background">
      <img name="img_viewer" pos="|0,|0" offset="-0.5,-0.5" size="0,0"/>
     </window>
     <sliderbar name="slider_zoom" size="30,-2" padding="5,20,5,20" min="20" max="500" value="100" vertical="1"/>
  </page>
</tabctrl>