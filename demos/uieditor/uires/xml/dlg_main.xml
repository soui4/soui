<?xml version="1.0"?>
<SOUI name="mainWindow" title="@string/title" bigIcon="ICON_LOGO:48" smallIcon="ICON_LOGO:32" width="1377" height="900" margin="5,5,5,5" resizable="1" wndType="appMain"
      sendWheel2Hover="1">
	<root colorBkgnd="#6f1111" padding="5,5,5,5">
		<window pos="1,[1,-1,-1" colorBkgnd="@color/bkBlack1" layout="vbox">
			<caption size="-2,30" name="UI_main_caption" show="1" font="adding:0" colorBkgnd="#FFFFFF20" layout="hbox" gravity="center">
				<icon src="ICON_LOGO:32"/>
				<text name="apptitle" class="ue_cls_title">@string/title</text>

				<window size="0,0" visible="0" weight="1"/>
				<imgbtn name="btn_help" skin="skin_help" tip="about" animate="1"/>
				<imgbtn name="btn_min" skin="_skin.sys.btn.minimize"  animate="1" />
				<window>
					<imgbtn name="btn_max" skin="_skin.sys.btn.maximize" pos="0,0" animate="1" />
					<imgbtn name="btn_restore" skin="_skin.sys.btn.restore" pos="0,0" show="0" animate="1" />
				</window>
				<imgbtn name="btn_close" skin="_skin.sys.btn.close" tip="close" animate="1" />
			</caption>
			<window size="-2,0" weight="1" layout="frame" enableDockMode="any">
				<!--menu bar-->
				<menubar name="main_menu" size="-2,36" dock="top">
					<btnstyle skin="skin_item_bk" colorText="@color/white" padding="2"/>
					<menus>
						<menuItem src="SMENU:MENU_FILE">文件(&F)</menuItem>
						<menuItem src="SMENU:MENU_VIEW">视图(&V)</menuItem>
						<menuItem src="SMENU:MENU_TOOL">工具(&T)</menuItem>
						<menuItem src="SMENU:MENU_HELP">帮助(&H)</menuItem>
					</menus>
				</menubar>
				<toolbar name="tb_main" dock="top" size="0,40" weight="1" skin="skin_item_bk" colorText="@color/white" colorTextDisable="@color/gray" iconSkin="skin_tb_main" dropArrowSkin="skin_dropdown" sepSkin="skin_tb_sep">
				  <data>
					<item  id="1" name="tb_main_openproject" text="@string/open_prject" iconIndex="0" dropdown="1" showText="1"/>
					<item  id="2" name="tb_main_closeproject" text="@string/close_prject" iconIndex="1" showText="1"/>
					<item  id="3" name="tb_main_savexml" text="@string/save_xml" iconIndex="2" showText="1"/>
					<sep/>
					<item  id="4" name="tb_main_newlayout" text="@string/new_layout" iconIndex="3" showText="1"/>
					<item  id="5" name="tb_main_newinclude" text="@string/new_include" iconIndex="4" showText="1"/>
					<sep/>
					<item  id="6" name="tb_main_formatxml" text="@string/format_xml" iconIndex="5" showText="1"/>
					<item  id="7" name="tb_main_viewskin" text="@string/view_skin" iconIndex="6" showText="1"/>
					<check name="chk_autosave" text="@string/auto_save"/>
					<sep/>
					<item  id="8" name="tb_main_about" text="@string/about" iconIndex="8" showText="1"/>
				  </data>
				</toolbar>
				<!--widget toolbar-->
				<toolbar name="tb_widget" dock="top" size="-2,40" skin="skin_item_bk" dropArrowSkin="skin_dropdown" display="0" visible="0"/>
				<!--skin toolbar-->
				<toolbar name="tb_skin" dock="top" size="-2,40" skin="skin_item_bk" dropArrowSkin="skin_dropdown" display="0" visible="0"/>
				<!--main designer-->
				<splitcol name="NAME_UIDESIGNER_split_col" dock="mainview" sepSkin="" sepSize="6">
					<pane idealSize="380" minSize="30" priority="1" clipClient="1">
						<include src="layout:xml_mainwnd_left" />
					</pane>
					<pane idealSize="800" minSize="30" priority="0" clipClient="1">
						<include src="layout:xml_uidesigner_main" />
					</pane>
				</splitcol>
				<dockbar width="300" dock="right" name="property_panel_dock" text="@string/property" resizable="1" margin="2">
					<include src="layout:property_panel" />
				</dockbar>
			</window>
		</window>
	</root>
</SOUI>
