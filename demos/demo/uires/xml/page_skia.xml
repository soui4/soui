<include>
  <tabctrl pos="0,[10,-0,-0" tabAlign="top" tabInterSize="2" tabHeight="30">

    <page title="filter level">
      <tabctrl pos="0,[10,-0,-0" tabAlign="top" tabInterSize="2" tabHeight="30">
        <page title="none">
          <img pos="0,0,-0,-0" skin="skin_avatar_none"/>
        </page>
        <page title="low">
          <img pos="0,0,-0,-0" skin="skin_avatar_low"/>
        </page>
        <page title="medium">
          <img pos="0,0,-0,-0" skin="skin_avatar_medium"/>
        </page>
        <page title="high">
          <img pos="0,0,-0,-0" skin="skin_avatar_high"/>
        </page>
      </tabctrl>
    </page>
    <page title="path" layout="vbox">

      <window size="-2,-1" layout="hbox">
        <text size="-1,-1">path, left button: add point, right button: remove point.</text>
        <text size="-1,-1" extend_left="10dp">path length:</text>
        <text size="-1,-1" name="txt_path_length" colorText="#ff0000">0</text>
      </window>
      
      <pathView size="-2,0" weight="1" cornerRadius="8" lineStyle="3" lineWidth="2" lineColor="#00ff00" name="pv_test">
        演示path
      </pathView>
    </page>
    <page title="SpeedMeter" layout="vbox">
        <window size="-1,-1" layout="hbox"> 
          <button name="btn_speed_dec" text="-" size="50,30"/>
          <button name="btn_speed_inc" text="+" size="50,30"/>
        </window>
        <SpeedMeter size="200,200" name="speed_ctrl" value="200" minValue="0" maxValue="300" RingWidth="16" />
    </page>
  </tabctrl>
</include>